{
  "name": "@endo/ocapn-noise",
  "version": "0.1.0",
  "private": true,
  "description": null,
  "keywords": [],
  "author": "Endo contributors",
  "license": "Apache-2.0",
  "homepage": "https://github.com/endojs/endo/tree/master/packages/ocapn-noise#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/endojs/endo.git",
    "directory": "packages/ocapn-noise"
  },
  "bugs": {
    "url": "https://github.com/endojs/endo/issues"
  },
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "exports": {
    ".": "./index.js",
    "./mock-transport": "./src/transports/mock.js",
    "./tcp-transport": {
      "node": "./src/transports/tcp.js"
    },
    "./ws-transport": "./src/transports/ws.js",
    "./wasm-module": "./gen/ocapn-noise.wasm",
    "./platform": {
      "node": "./src/wasm/node.js",
      "browser": "./src/wasm/browser.js",
      "default": "./src/wasm/browser.js"
    },
    "./types": {
      "types": "./src/types.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "exit 0",
    "lint": "yarn lint:types && yarn lint:eslint",
    "lint-fix": "yarn lint:eslint --fix && yarn lint:types",
    "lint:eslint": "eslint '**/*.js'",
    "lint:types": "tsc",
    "postpack": "git clean -fX -e node_modules/",
    "prepack": "git clean -fX -e node_modules/ && tsc --build tsconfig.build.json",
    "test": "ses-ava",
    "test:c8": "c8 ${C8_OPTIONS:-} ses-ava",
    "test:xs": "exit 0"
  },
  "dependencies": {
    "@endo/harden": "workspace:^",
    "@endo/netstring": "workspace:^",
    "@endo/ocapn": "workspace:^",
    "@endo/stream": "workspace:^",
    "@endo/stream-node": "workspace:^"
  },
  "devDependencies": {
    "@endo/eventual-send": "workspace:^",
    "@endo/init": "workspace:^",
    "@endo/lockdown": "workspace:^",
    "@endo/marshal": "workspace:^",
    "@endo/ses-ava": "workspace:^",
    "ava": "catalog:dev",
    "c8": "catalog:dev",
    "eslint": "catalog:dev",
    "ses": "workspace:^",
    "tsd": "catalog:dev",
    "typescript": "~5.9.2"
  },
  "files": [
    "./*.d.ts",
    "./*.js",
    "./*.map",
    "LICENSE*",
    "SECURITY*",
    "dist",
    "gen",
    "lib",
    "src",
    "tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "eslintConfig": {
    "extends": [
      "plugin:@endo/internal"
    ]
  },
  "sesAvaConfigs": {
    "lockdown": "../../ava-endo-lockdown.config.mjs",
    "unsafe": "../../ava-endo-lockdown-unsafe.config.mjs",
    "endo": "../../ava-endo-shims-only.config.mjs"
  }
}
